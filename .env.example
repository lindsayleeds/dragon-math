# Server env vars. Copy to `.env` (which is gitignored) and fill in real values.

# JWT signing secret for auth tokens. Generate with: openssl rand -hex 32
JWT_SECRET=

# Public base URL used in outgoing emails (e.g. weekly digest "Open dashboard").
APP_PUBLIC_URL=http://localhost:5173

# Set to 1 to enable scheduled cron jobs (weekly digest, etc.) outside of prod.
# In production (NODE_ENV=production) cron runs regardless.
ENABLE_CRON=0

# Supabase Postgres connection string (Session pooler — supports prepared statements).
# Find it in: Supabase dashboard -> Project Settings -> Database -> Connection string -> Session pooler.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-us-west-1.pooler.supabase.com:5432/postgres
